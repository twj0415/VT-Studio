{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.ts",
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts"
  ],
  "compilerOptions": {
    "incremental": false,
    "tsBuildInfoFile": "./node_modules/.cache/vt-studio/tsconfig.node.tsbuildinfo",
    "types": [
      "node",
      "electron-vite/node"
    ],
    "baseUrl": ".",
    "paths": {
      "@shared/*": [
        "src/shared/*"
      ]
    }
  }
}

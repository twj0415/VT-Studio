{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VT AI Short Video Maker",
  "version": "0.1.0",
  "identifier": "com.vt-ai-short-video-maker.app",
  "build": {
    "beforeDevCommand": "pnpm --dir frontend dev",
    "beforeBuildCommand": "pnpm --dir frontend build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "VT AI Short Video Maker",
        "width": 1440,
        "height": 900,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": false
  }
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VT AI Short Video Maker",
  "version": "0.1.0",
  "identifier": "com.vt-ai-short-video-maker.app",
  "build": {
    "beforeDevCommand": "pnpm --dir src dev",
    "beforeBuildCommand": "pnpm --dir src build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../src/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "VT AI Short Video Maker",
        "width": 1440,
        "height": 900,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "resources": [
      "../resources/bin/**/*",
      "../resources/licenses/**/*"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "English",
          "SimpChinese"
        ],
        "displayLanguageSelector": true
      }
    }
  }
}
